{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "workspace",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "bindings/*",
      "dotconfig/*",
      "runtime"
    ],
    "catalog": {
      "effect": "^4.0.0-beta.52",
      "@effect/platform-bun": "^4.0.0-beta.52",
      "@effect/vitest": "^4.0.0-beta.52",
      "typescript": "^5.9.3",
      "@effect/language-service": "^0.73.0",
      "@types/bun": "^1.3.8",
      "smol-toml": "^1.6.0",
      "vitest": "^4.0.18"
    }
  },
  "type": "module",
  "scripts": {
    "build": "vp build",
    "check": "vp check",
    "dev": "vp dev",
    "gen:zellij-layouts": "bun run scripts/generate-zellij-layout-kdl-files.ts",
    "install:dotconfig": "vp run install:dotconfig",
    "lint": "vp check",
    "prepare": "effect-language-service patch",
    "test": "vp test"
  },
  "dependencies": {
    "@effect/platform-bun": "catalog:",
    "@workspace/zellij-binding": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "^0.1.14",
    "vitest": "catalog:"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.14",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.14"
  },
  "packageManager": "bun@1.3.11"
}
