{
	"name": "workspace",
	"private": true,
	"packageManager": "bun@1.3.8",
	"scripts": {
		"build": "turbo build",
		"check": "turbo typecheck lint test",
		"clean": "turbo clean",
		"dev": "turbo dev",
		"install:dotconfig": "turbo install:dotconfig",
		"lint": "turbo lint",
		"prepare": "effect-language-service patch",
		"test": "turbo test",
		"typecheck": "turbo typecheck"
	},
	"dependencies": {
		"effect": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@effect/language-service": "catalog:",
		"@effect/vitest": "catalog:",
		"@types/bun": "catalog:",
		"turbo": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},

	"$schema": "https://www.schemastore.org/package.json",
	"workspaces": {
		"packages": [
			"apps/*",
			"bindings/*",
			"dotconfig/*",
			"runtime"
		],
		"catalog": {
			"effect": "^4.0.0-beta.20",
			"@effect/platform-bun": "^4.0.0-beta.20",
			"@effect/vitest": "^4.0.0-beta.20",
			"typescript": "^5.9.3",
			"@biomejs/biome": "^2.3.14",
			"@effect/language-service": "^0.73.0",
			"@types/bun": "^1.3.8",
			"smol-toml": "^1.6.0",
			"vitest": "^4.0.18",
			"turbo": "^2.8.3"
		}
	}
}
