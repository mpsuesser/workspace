layout {
	cwd "/Users/m/repos"

	pane split_direction="vertical" {
		// Left: 20-col vertical sessions sidebar
		// (@workspace/zellij-vertical-sessions-bar). Borderless so the full
		// 20 cols are usable content. Replaces the previous wasm plugin
		// (Rust crate at /Users/m/repos/zellij-vertical-sessions-bar) with a
		// Bun + OpenTUI program that drives the same UI through the
		// @workspace/zellij-binding service surface.
		//
		// `--watch` is a hard restart on file change — the sidebar carries
		// per-process state (OpenTUI renderer, key listeners, polling fiber
		// on the WorkspaceRuntime) that `--hot` would leak across reloads,
		// so a clean process restart is the right model here.
		pane size=20 borderless=true command="bun" {
			args "run" "--watch" "/Users/m/repos/workspace/apps/zellij-vertical-sessions-bar/src/main.ts"
		}
		// Right: the actual workspace pane that takes focus on startup.
		pane {
			focus true
		}
	}
}
