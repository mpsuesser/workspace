config-file = "./keys"
config-file = "./keys-using-zellij"
config-file = "./shader"

shell-integration = "zsh"

# Zellij-friendly shell integration:
# - no-cursor: zellij manages cursor per pane; avoid fighting it
# - no-title:  zellij manages pane titles
# - sudo:      preserve terminfo across sudo (harmless, useful)
# - ssh-env:   translate TERM=xterm-ghostty on remote hosts
# - ssh-terminfo: auto-install ghostty's terminfo on remote hosts
shell-integration-features = no-cursor, no-title, sudo, ssh-env, ssh-terminfo

# Force Option to behave as Alt so zellij Alt+w/s/e bindings fire reliably,
# rather than depending on keyboard-layout-specific ghostty defaults.
macos-option-as-alt = true

# theme = prisma-dark
theme = Snazzy

# Pin split divider to match zellij frame color (see zellij/themes/dracula.kdl).
# Without this, macOS ghostty uses NSColor.separatorColor, which is close but
# dynamic and won't stay in lockstep with the zellij theme.
split-divider-color = #3a3a3a

# Mouse-drag text selection inside zellij panes is rendered by ghostty, not
# zellij (zellij has no theme key for pane selection — see issue #3452). The
# default (inverted fg/bg) is too subtle against our Snazzy background, so
# we set these explicitly to the dracula selection color #44475a for a
# consistent, clearly visible highlight across zellij + ghostty.
selection-background = #44475a
selection-foreground = #f8f8f2

# font-family = Maple Mono
font-family = Maple Mono NF
# font-family = Annotation Mono
# font-family = JetBrainsMono Nerd Font Mono
# font-family = JetBrainsMonoNL Nerd Font Mono
# font-family = Monaspace Neon
# font-family = Monaspace Argon
# font-family = Monaspace Xenon
# font-family = Monaspace Krypton
# font-family = Monaspace Radon
# font-family = IosevkaTerm Nerd Font Mono
# font-family = CommitMono Nerd Font Mono
# font-family = GeistMono Nerd Font Mono
# font-family = Hack Nerd Font Mono
# font-family = Menlo

quick-terminal-position = center
quick-terminal-size = 33%,85%
quick-terminal-screen = main
quick-terminal-animation-duration = 0
quick-terminal-autohide = true
quick-terminal-space-behavior = move

background-opacity = 1
background-blur = 16
background-blur-radius = 10

maximize = true
fullscreen = non-native
window-decoration = none

window-padding-x = 8
window-padding-y = 8
window-padding-color = extend

confirm-close-surface = false

cursor-style = bar

title = "Ghostty"

# Launch into tmux — sessions persist across Ghostty restarts
# command = /bin/zsh -l -c 'exec tmux'

initial-window = false

link-url = true

auto-update = "check"
auto-update-channel = "tip"
