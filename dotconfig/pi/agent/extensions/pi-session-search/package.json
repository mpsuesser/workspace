    "pi-coding-agent",
    "search",
    "sessions",
    "fts5",
    "sqlite"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaiserlich-dev/pi-session-search"
  },
  "publishConfig": {
