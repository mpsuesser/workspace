{
	"name": "pi-zellij-sessions-bar-integration",
	"version": "0.0.0",
	"private": true,
	"description": "Pi-side integration for the zellij vertical sessions bar — feeds {description} and {state} for the current session.",
	"keywords": [
		"pi-package",
		"pi-extension"
	],
	"type": "module",
	"exports": {
		".": "./index.ts",
		"./state": "./src/state.ts"
	},
	"files": [
		"index.ts",
		"src",
		"README.md",
		"tsconfig.json"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"dependencies": {
		"@workspace/runtime": "workspace:*",
		"@workspace/zellij-binding": "workspace:*",
		"effect": "catalog:effect"
	}
}
