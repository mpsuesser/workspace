{
	"$schema": "https://www.schemastore.org/package.json",
	"name": "pi-web-access",
	"version": "0.10.6",
	"description": "Web search, URL fetching, GitHub repo cloning, PDF extraction, YouTube video understanding, and local video analysis for Pi coding agent",
	"keywords": [
		"extension",
		"fetch",
		"perplexity",
		"pi",
		"pi-coding-agent",
		"pi-extension",
		"pi-package",
		"scraping",
		"web-search"
	],
	"homepage": "https://github.com/nicobailon/pi-web-access#readme",
	"bugs": {
		"url": "https://github.com/nicobailon/pi-web-access/issues"
	},
	"license": "MIT",
	"author": "Nico Bailon",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nicobailon/pi-web-access.git"
	},
	"files": [
		"*.ts",
		"skills",
		"README.md",
		"LICENSE",
		"CHANGELOG.md",
		"banner.png",
		"pi-web-fetch-demo.mp4"
	],
	"type": "module",
	"exports": {
		".": {
			"import": "./index.ts"
		}
	},
	"scripts": {
		"check": "vp check --fix",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@mozilla/readability": "^0.5.0",
		"linkedom": "^0.16.0",
		"p-limit": "^6.1.0",
		"turndown": "^7.2.0",
		"unpdf": "^1.4.0"
	},
	"devDependencies": {
		"@mariozechner/pi-ai": "^0.67.2",
		"@mariozechner/pi-coding-agent": "^0.67.2",
		"@mariozechner/pi-tui": "^0.67.2",
		"@sinclair/typebox": "^0.34.49",
		"@types/bun": "^1.3.10",
		"@types/turndown": "^5.0.5",
		"typescript": "^5.9.3",
		"vite-plus": "^0.1.15",
		"vitest": "^4.1.0"
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*",
		"@sinclair/typebox": "*"
	},
	"engines": {
		"bun": ">=1.3.11",
		"node": ">=20.0.0"
	},
	"packageManager": "bun@1.3.11",
	"pi": {
		"extensions": [
			"./index.ts"
		],
		"skills": [
			"./skills"
		],
		"video": "https://github.com/nicobailon/pi-web-access/raw/refs/heads/main/pi-web-fetch-demo.mp4"
	}
}
