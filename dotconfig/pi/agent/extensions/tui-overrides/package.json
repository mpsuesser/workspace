{
  "name": "pi-tui-overrides",
  "version": "0.3.1",
  "description": "TUI overrides, tool rendering, and interactive UI patches for Pi coding agent. Keeps tool output compact while customizing core chat presentation.",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "src",
    "config/config.example.json",
    "assets/pi-tui-overrides.png",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npx --yes -p typescript@6.0.2 tsc -p tsconfig.json --noCheck",
    "lint": "npm run build",
    "test": "npx --yes tsx --test tests/*.test.ts",
    "check": "npm run lint && npm run test"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "pi-tui",
    "coding-agent",
    "tui",
    "tool-rendering",
    "tool-output",
    "diff-visualization",
    "output-truncation",
    "hide",
    "collapse",
    "truncate",
    "compact",
    "diff",
    "output-mode",
    "tui-overrides",
    "ui-patches"
  ],
  "author": "MasuRii",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MasuRii/pi-tui-overrides.git"
  },
  "bugs": {
    "url": "https://github.com/MasuRii/pi-tui-overrides/issues"
  },
  "homepage": "https://github.com/MasuRii/pi-tui-overrides#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.1",
    "@mariozechner/pi-tui": "^0.67.1"
  },
  "overrides": {
    "file-type": ">=21.3.1"
  }
}
