{
  "editor.wordSeparators": "`~!@$%^&*()=+[{]}\\|;:'\",<>\/.?",
  "editor.formatOnSave": true,
  "breadcrumbs.enabled": true,
  "editor.cursorSmoothCaretAnimation": "off",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "editor.fontFamily": "annotation mono, monaco, monospace",
  "editor.formatOnPaste": true,
  "editor.defaultFormatter": "vscode.typescript-language-features",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "workbench.editor.showTabs": "multiple",
  "search.showLineNumbers": true,
  "editor.accessibilitySupport": "off",
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "oxc.lint.run": "onSave",
  "diffEditor.hideUnchangedRegions.enabled": true,
  "explorer.compactFolders": false,
  "typescript.preferences.preferTypeOnlyAutoImports": true,
  "typescript.experimental.expandableHover": true,
  "typescriptHero.imports.organizeOnSave": true,
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true
  },
  "files.exclude": {
    "**/.git": false,
    "node_modules": true,
    "bun.lock": true,
    ".github": false,
    ".git": true,
    "nexus": false,
    "inbox": false,
    ".n": false,
    ".i": false,
    ".logs": false,
    "tsconfig.json": false,
    ".oxlintrc.json": false,
    "dprint.json": false,
    "bunfig.toml": false,
    ".gitignore": false
  },
  "[search-result]": {
    "editor.lineNumbers": "on"
  },
  "cursor.cpp.disabledLanguages": ["markdown", "plaintext", "untitled"],
  "repomix.output.includeEmptyDirectories": true,
  "repomix.ignore.customPatterns": ["node_modules"],
  "editor.useTabStops": false,
  "editor.guides.indentation": false,
  "editor.wordWrap": "on",
  "cursor.composer.shouldAllowCustomModes": true,
  "cursor.terminal.usePreviewBox": true,
  "cursor.diffs.useCharacterLevelDiffs": true,
  "cursor.windowSwitcher.sidebarHoverCollapsed": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "workbench.colorTheme": "Vesper",
  "workbench.colorCustomizations": {},
  "evenBetterToml.formatter.alignComments": true,
  "evenBetterToml.formatter.alignEntries": true,
  // ---------------------------------------------------------------------------
  // VSCodeVim - ported from ~/repos/workspace/dotconfig/nvim
  // ---------------------------------------------------------------------------
  "vim.cursorStylePerMode.insert": "line",
  "vim.cursorStylePerMode.normal": "block",
  "vim.cursorStylePerMode.visual": "line-thin",
  "vim.cursorStylePerMode.visualline": "line-thin",
  "vim.cursorStylePerMode.visualblock": "line-thin",
  "vim.cursorStylePerMode.replace": "block",

  // Match nvim options.lua as closely as VSCodeVim allows.
  "vim.useSystemClipboard": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.ignorecase": true,
  "vim.smartcase": true,
  "vim.timeout": 400,
  "vim.report": 9999,
  "vim.textwidth": 0,
  "vim.showmodename": false,
  "vim.whichwrap": "b,s,h,l,<,>,[,]",
  "vim.easymotion": true,
  "vim.easymotionKeys": "qweasdrf",
  "vim.surround": true,
  "vim.replaceWithRegister": true,
  "vim.leader": "<space>",

  // ---------------------------------------------------------------------------
  // NORMAL MODE - Movement, editing, navigation, and leaders
  // ---------------------------------------------------------------------------
  "vim.normalModeKeyBindingsNonRecursive": [
    // WASD movement on wrapped/visual lines.
    { "before": ["w"], "commands": [{ "command": "cursorMove", "args": { "to": "up", "by": "wrappedLine", "value": 1 } }] },
    { "before": ["s"], "commands": [{ "command": "cursorMove", "args": { "to": "down", "by": "wrappedLine", "value": 1 } }] },
    { "before": ["a"], "commands": ["cursorLeft"] },
    { "before": ["d"], "commands": ["cursorRight"] },
    { "before": ["<left>"], "commands": ["cursorLeft"] },
    { "before": ["<right>"], "commands": ["cursorRight"] },
    { "before": ["W"], "commands": [{ "command": "cursorMove", "args": { "to": "up", "by": "wrappedLine", "value": 5 } }] },
    { "before": ["S"], "commands": [{ "command": "cursorMove", "args": { "to": "down", "by": "wrappedLine", "value": 5 } }] },
    { "before": ["A"], "after": ["0"] },
    { "before": ["D"], "commands": ["cursorEnd"] },

    // Mode switching and open-line commands.
    { "before": ["q"], "after": ["i"] },
    { "before": ["o"], "after": ["o"] },
    { "before": ["O"], "after": ["O"] },
    { "before": ["r"], "after": ["v"] },
    { "before": ["v"], "after": ["v"] },

    // Editing grammar.
    { "before": ["e"], "after": ["\"", "_", "s"] },
    { "before": ["c"], "after": ["y", "l"] },
    { "before": ["x"], "after": ["v", "i", "b"] },
    { "before": ["u"], "after": ["a", "q", "u"] },
    { "before": ["k"], "after": ["u"] },
    { "before": ["K"], "after": ["<C-r>"] },
    { "before": ["{"], "after": ["v", "i", "b"] },
    { "before": ["}"], "after": ["v", "a", "b"] },
    { "before": ["Q"], "after": ["\"", "_", "d", "d"] },
    { "before": ["R"], "after": ["y", "y"] },
    { "before": ["X"], "after": ["d", "d"] },
    { "before": ["p"], "after": ["p"] },
    { "before": ["E"], "after": ["\"", "_", "x", "P"] },
    { "before": ["<"], "commands": ["editor.action.outdentLines"] },
    { "before": [">"], "commands": ["editor.action.indentLines"] },

    // Navigation and search.
    { "before": ["g", "g"], "after": ["g", "g"] },
    { "before": ["G"], "after": ["G"] },
    { "before": ["F"], "after": ["/"] },
    { "before": ["f"], "after": ["<leader>", "<leader>", "w"] },
    { "before": ["z", "R"], "commands": ["editor.unfoldAll"] },
    { "before": ["z", "M"], "commands": ["editor.foldAll"] },

    // Markdown bold helpers from nvim's custom b mapping.
    {
      "before": ["b"],
      "commands": [
        "editor.action.smartSelect.expand",
        { "command": "editor.action.insertSnippet", "args": { "snippet": "**${TM_SELECTED_TEXT:${TM_CURRENT_WORD}}**" } },
        "extension.vim_escape"
      ]
    },

    // Jump prefix (j).
    { "before": ["j", "w"], "after": ["g", "g"] },
    { "before": ["j", "a"], "after": ["0"] },
    { "before": ["j", "s"], "after": ["G"] },
    { "before": ["j", "d"], "commands": ["cursorEnd"] },
    { "before": ["j", "l"], "commands": ["cursorEnd"] },

    // Commenting.
    { "before": ["<leader>", "c"], "commands": ["editor.action.commentLine"] },
    { "before": [";", "c"], "commands": ["editor.action.commentLine"] },

    // Space leader: save/quit and selection helpers.
    { "before": ["<leader>", "q"], "commands": ["workbench.action.files.save", "workbench.action.closeActiveEditor"] },
    { "before": ["<leader>", "Q"], "commands": ["workbench.action.revertAndCloseActiveEditor"] },
    { "before": ["<leader>", "w"], "after": ["v", "i", "w"] },
    { "before": ["<leader>", "W"], "after": ["v", "i", "W"] },
    { "before": ["<leader>", "A"], "after": ["0"] },
    { "before": ["<leader>", "S"], "after": ["V"] },
    { "before": ["<leader>", "i"], "after": ["v", "i"] },
    { "before": ["<leader>", "d"], "after": ["$", "h", "h", "h", "v", "i", "w"] },
    { "before": ["<leader>", "e"], "after": ["v", "a", "b", "\"", "_", "c"] },
    { "before": ["<leader>", "a"], "after": ["g", "g", "V", "G"] },
    { "before": ["<leader>", "<space>"], "after": ["g", "g", "V", "G"] },
    { "before": ["<leader>", "s"], "commands": ["workbench.action.toggleStatusbarVisibility"] },
    { "before": ["<leader>", "f"], "after": ["V"] },
    { "before": ["<leader>", "t"], "after": ["<leader>", "<leader>", "<leader>", "j"] },

    // Semicolon leader duplicates.
    { "before": [";", "q"], "commands": ["workbench.action.files.save", "workbench.action.closeActiveEditor"] },
    { "before": [";", "Q"], "commands": ["workbench.action.revertAndCloseActiveEditor"] },
    { "before": [";", "w"], "after": ["v", "i", "w"] },
    { "before": [";", "W"], "after": ["v", "i", "W"] },
    { "before": [";", "A"], "after": ["0"] },
    { "before": [";", "S"], "after": ["V"] },
    { "before": [";", "i"], "after": ["v", "i"] },
    { "before": [";", "e"], "after": ["v", "a", "b", "\"", "_", "c"] },
    { "before": [";", "a"], "after": ["g", "g", "V", "G"] },
    { "before": [";", "<space>"], "after": ["g", "g", "V", "G"] },
    { "before": [";", "s"], "after": ["y", "s", "i"] },
    { "before": [";", "f"], "after": ["V"] },
    { "before": [";", ";"], "commands": ["workbench.actions.view.problems"] },

    // Telescope / picker equivalents.
    { "before": ["<leader>", "p"], "commands": ["workbench.action.quickOpen"] },
    { "before": ["<leader>", "g"], "commands": ["workbench.action.findInFiles"] },
    { "before": ["<leader>", "b"], "commands": ["workbench.action.showAllEditors"] },
    { "before": ["<leader>", "/"], "commands": ["actions.find"] },
    { "before": ["<leader>", "l", "d"], "commands": ["workbench.actions.view.problems"] },
    { "before": ["<leader>", "l", "s"], "commands": ["workbench.action.gotoSymbol"] },
    { "before": [";", "p"], "commands": ["workbench.action.quickOpen"] },
    { "before": [";", "g"], "commands": ["workbench.action.findInFiles"] },
    { "before": [";", "b"], "commands": ["workbench.action.showAllEditors"] },

    // Explorer / diagnostics / formatting / UI extras.
    { "before": ["<leader>", "n"], "commands": ["workbench.view.explorer"] },
    { "before": [";", "n"], "commands": ["workbench.view.explorer"] },
    { "before": ["<leader>", "l", "x"], "commands": ["workbench.actions.view.problems"] },
    { "before": ["<leader>", "l", "X"], "commands": ["workbench.actions.view.problems"] },
    { "before": ["<leader>", "l", "r"], "commands": ["references-view.findReferences"] },
    { "before": ["<leader>", "l", "q"], "commands": ["workbench.actions.view.problems"] },
    { "before": ["<leader>", "l", "l"], "commands": ["workbench.actions.view.problems"] },
    { "before": ["<leader>", "l", "f"], "commands": ["editor.action.formatDocument"] },
    { "before": ["<leader>", "u", "h"], "commands": ["notifications.showList"] },
    { "before": ["<leader>", "u", "l"], "commands": ["notifications.showList"] },
    { "before": ["<leader>", "u", "d"], "commands": ["notifications.clearAll"] },
    { "before": ["<leader>", "u", "m"], "commands": ["markdown.showPreview"] },
    { "before": ["<leader>", "u", "z"], "commands": ["workbench.action.toggleZenMode"] },
    { "before": ["<leader>", "u", "u"], "commands": ["workbench.action.openPreviousRecentlyUsedEditorInGroup"] },
    { "before": ["<leader>", "k"], "commands": ["workbench.action.openPreviousRecentlyUsedEditorInGroup"] },

    // Cursor replacements for the nvim OpenCode/pi.nvim integration maps.
    { "before": ["<leader>", "o", "g"], "commands": ["composerMode.agent", "composer.openAsPane", "composer.focusComposer"] },
    { "before": ["<leader>", "o", "i"], "commands": ["composer.focusComposer"] },
    { "before": ["<leader>", "o", "I"], "commands": ["composer.createNew", "composerMode.agent", "composer.focusComposer"] },
    { "before": ["<leader>", "o", "o"], "commands": ["composer.openChatAsEditor"] },
    { "before": ["<leader>", "o", "t"], "commands": ["composer.focusComposer"] },
    { "before": ["<leader>", "o", "s"], "commands": ["composer.showComposerHistory"] },
    { "before": ["<leader>", "p", "a"], "commands": ["composerMode.agent", "composer.focusComposer"] },
    { "before": ["<leader>", "p", "s"], "commands": ["composer.startComposerPromptFromSelection"] },
    { "before": ["<leader>", "p", "c"], "commands": ["composer.cancelChat"] },
    { "before": ["<leader>", "p", "l"], "commands": ["composer.showComposerHistory"] },

    // LSP/navigation equivalents.
    { "before": ["g", "d"], "commands": ["editor.action.revealDefinition"] },
    { "before": ["g", "D"], "commands": ["editor.action.revealDeclaration"] },
    { "before": ["g", "i"], "commands": ["editor.action.goToImplementation"] },
    { "before": ["g", "r"], "commands": ["editor.action.goToReferences"] },
    { "before": ["g", "t"], "commands": ["editor.action.goToTypeDefinition"] },
    { "before": ["<leader>", "r"], "commands": ["editor.action.rename"] },
    { "before": ["<leader>", "c", "a"], "commands": ["editor.action.quickFix"] },
    { "before": ["<leader>", "h"], "commands": ["editor.action.showHover"] },
    { "before": ["[", "d"], "commands": ["editor.action.marker.prev"] },
    { "before": ["]", "d"], "commands": ["editor.action.marker.next"] },

    // Window navigation, matching <C-w>{w,s,a,d} in nvim.
    { "before": ["<C-w>", "w"], "commands": ["workbench.action.navigateUp"] },
    { "before": ["<C-w>", "s"], "commands": ["workbench.action.navigateDown"] },
    { "before": ["<C-w>", "a"], "commands": ["workbench.action.navigateLeft"] },
    { "before": ["<C-w>", "d"], "commands": ["workbench.action.navigateRight"] }
  ],

  // ---------------------------------------------------------------------------
  // VISUAL MODE - movement/selection/editing
  // ---------------------------------------------------------------------------
  "vim.visualModeKeyBindingsNonRecursive": [
    { "before": ["w"], "commands": [{ "command": "cursorMove", "args": { "to": "up", "by": "wrappedLine", "value": 1, "select": true } }] },
    { "before": ["s"], "commands": [{ "command": "cursorMove", "args": { "to": "down", "by": "wrappedLine", "value": 1, "select": true } }] },
    { "before": ["a"], "after": ["h"] },
    { "before": ["d"], "after": ["l"] },
    { "before": ["W"], "commands": [{ "command": "cursorMove", "args": { "to": "up", "by": "wrappedLine", "value": 5, "select": true } }] },
    { "before": ["S"], "commands": [{ "command": "cursorMove", "args": { "to": "down", "by": "wrappedLine", "value": 5, "select": true } }] },
    { "before": ["A"], "after": ["b"] },
    { "before": ["D"], "after": ["e"] },
    { "before": ["g", "l"], "after": ["$"] },
    { "before": ["r"], "after": ["V"] },
    { "before": ["f"], "after": ["<leader>", "<leader>", "w"] },
    { "before": ["<leader>", "t"], "after": ["<leader>", "<leader>", "<leader>", "j"] },
    { "before": ["<"], "commands": ["editor.action.outdentLines"] },
    { "before": [">"], "commands": ["editor.action.indentLines"] },
    { "before": ["x"], "after": ["\"", "_", "d"] },
    { "before": ["X"], "after": ["d"] },
    { "before": ["e"], "after": ["\"", "_", "c"] },
    { "before": ["c"], "after": ["y"] },
    {
      "before": ["b"],
      "commands": [
        { "command": "editor.action.insertSnippet", "args": { "snippet": "**${TM_SELECTED_TEXT}**" } },
        "extension.vim_escape"
      ]
    },
    { "before": ["<leader>", "c"], "commands": ["editor.action.commentLine"] },
    { "before": [";", "c"], "commands": ["editor.action.commentLine"] }
  ],

  // Flash's operator-pending mode is approximated with VSCodeVim EasyMotion.
  "vim.operatorPendingModeKeyBindingsNonRecursive": [
    { "before": ["f"], "after": ["<leader>", "<leader>", "w"] },
    { "before": ["<leader>", "t"], "after": ["<leader>", "<leader>", "<leader>", "j"] }
  ],

  // ---------------------------------------------------------------------------
  // INSERT MODE
  // ---------------------------------------------------------------------------
  "vim.insertModeKeyBindingsNonRecursive": [
    { "before": ["q"], "after": ["<Esc>", "l"] }
  ],

  // Let native VS Code/Cursor keybindings win for Cmd-A/D tab navigation.
  "vim.handleKeys": {
    "<D-a>": false,
    "<D-d>": false
  },

  // To improve VSCodeVim responsiveness.
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  },

  // Claude Code
  "claudeCode.preferredLocation": "panel",
  "window.autoDetectColorScheme": false
}
