// Place your key bindings in this file to override the defaults
[
  // Cursor / existing dotconfig shortcuts
  {
    "key": "cmd+i",
    "command": "composerMode.agent"
  },
  {
    "key": "cmd+a",
    "command": "workbench.action.previousEditor"
  },
  {
    "key": "cmd+d",
    "command": "workbench.action.nextEditor"
  },
  {
    "key": "cmd+shift+w",
    "command": "workbench.action.closeOtherEditors"
  },
  {
    "key": "cmd+shift+i",
    "command": "workbench.action.tasks.runTask",
    "args": "Bun Format"
  },

  // nvim: <M-a>/<M-d> focus left/right pane in normal/visual/insert/terminal.
  {
    "key": "alt+a",
    "command": "workbench.action.navigateLeft"
  },
  {
    "key": "alt+d",
    "command": "workbench.action.navigateRight"
  },

  // nvim insert-mode line navigation: <D-;> / <D-S-;>.
  {
    "key": "cmd+;",
    "command": "cursorEnd",
    "when": "editorTextFocus && vim.active && vim.mode == 'Insert'"
  },
  {
    "key": "cmd+shift+;",
    "command": "cursorHome",
    "when": "editorTextFocus && vim.active && vim.mode == 'Insert'"
  },

  // nvim insert-mode Option+Backspace -> delete previous word.
  {
    "key": "alt+backspace",
    "command": "deleteWordLeft",
    "when": "editorTextFocus && vim.active && vim.mode == 'Insert'"
  },

  // nvim picker/explorer feel: WASD in VS Code lists/quick open results.
  {
    "key": "w",
    "command": "list.focusUp",
    "when": "listFocus && !inputFocus"
  },
  {
    "key": "s",
    "command": "list.focusDown",
    "when": "listFocus && !inputFocus"
  },
  {
    "key": "a",
    "command": "list.collapse",
    "when": "listFocus && !inputFocus"
  },
  {
    "key": "d",
    "command": "list.select",
    "when": "listFocus && !inputFocus"
  },
  {
    "key": "q",
    "command": "workbench.action.closeSidebar",
    "when": "sideBarFocus && !inputFocus"
  },
  {
    "key": "ctrl+w",
    "command": "workbench.action.quickOpenSelectPrevious",
    "when": "inQuickOpen"
  },
  {
    "key": "ctrl+s",
    "command": "workbench.action.quickOpenSelectNext",
    "when": "inQuickOpen"
  }
]
