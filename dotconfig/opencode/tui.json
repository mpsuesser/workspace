{
  "$schema": "https://opencode.ai/tui.json",
  "keybinds": {
    "leader": "ctrl+x",
    "agent_list": "ctrl+a",
    "session_fork": "ctrl+f,alt+f",
    "session_list": "ctrl+o,alt+o,alt+l",
    "messages_page_up": "ctrl+w",
    "messages_page_down": "ctrl+s",
    "model_list": "ctrl+l,alt+m",
    "editor_open": "ctrl+e,alt+e"
  },
  "scroll_acceleration": {
    "enabled": true
  }
}
