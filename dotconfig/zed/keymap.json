[
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      "space": null,

      "w": ["vim::Up", { "display_lines": true }],
      "s": ["vim::Down", { "display_lines": true }],
      "a": "vim::WrappingLeft",
      "d": "vim::WrappingRight",
      "left": "vim::WrappingLeft",
      "right": "vim::WrappingRight",
      "shift-w": [
        "action::Sequence",
        [
          ["vim::Up", { "display_lines": true }],
          ["vim::Up", { "display_lines": true }],
          ["vim::Up", { "display_lines": true }],
          ["vim::Up", { "display_lines": true }],
          ["vim::Up", { "display_lines": true }]
        ]
      ],
      "shift-s": [
        "action::Sequence",
        [
          ["vim::Down", { "display_lines": true }],
          ["vim::Down", { "display_lines": true }],
          ["vim::Down", { "display_lines": true }],
          ["vim::Down", { "display_lines": true }],
          ["vim::Down", { "display_lines": true }]
        ]
      ],
      "shift-a": "vim::StartOfLine",
      "shift-d": "vim::EndOfLine",

      "q": "vim::InsertBefore",
      "o": "vim::InsertLineBelow",
      "shift-o": "vim::InsertLineAbove",
      "e": "vim::HelixSubstituteNoYank",
      "c": ["workspace::SendKeystrokes", "y l"],
      "x": ["workspace::SendKeystrokes", "v i b"],
      "u": [
        "action::Sequence",
        [
          ["vim::InsertBefore", {}],
          ["editor::InsertSnippet", { "snippet": "qu" }]
        ]
      ],
      "k": "vim::Undo",
      "shift-k": "vim::Redo",
      "r": "vim::ToggleVisual",
      "v": "vim::ToggleVisual",
      "{": ["workspace::SendKeystrokes", "v i b"],
      "}": ["workspace::SendKeystrokes", "v a b"],

      "shift-q": "editor::DeleteLine",
      "shift-r": "vim::YankLine",
      "shift-x": [
        "action::Sequence",
        [
          ["vim::PushDelete", {}],
          ["vim::CurrentLine", {}]
        ]
      ],
      "<": [
        "action::Sequence",
        [
          ["vim::PushOutdent", {}],
          ["vim::CurrentLine", {}]
        ]
      ],
      ">": [
        "action::Sequence",
        [
          ["vim::PushIndent", {}],
          ["vim::CurrentLine", {}]
        ]
      ],

      "g g": "vim::StartOfDocument",
      "shift-g": "vim::EndOfDocument",
      "f": "vim::HelixJumpToWord",
      "shift-f": "vim::Search",

      "j w": "vim::StartOfDocument",
      "j a": "vim::StartOfLine",
      "j s": "vim::EndOfDocument",
      "j d": "vim::EndOfLine",
      "j l": "vim::EndOfLine",

      "space q": ["pane::CloseActiveItem", { "save_intent": "save_all" }],
      "space shift-q": ["pane::CloseActiveItem", { "save_intent": "skip" }],
      "space w": ["workspace::SendKeystrokes", "v i w"],
      "space shift-w": ["workspace::SendKeystrokes", "v i shift-w"],
      "space shift-a": "vim::StartOfLine",
      "space shift-s": "vim::ToggleVisualLine",
      "space i": ["workspace::SendKeystrokes", "v i"],
      "space d": ["workspace::SendKeystrokes", "$ h h h v i w"],
      "space e": ["workspace::SendKeystrokes", "v a b e"],
      "space a": "editor::SelectAll",
      "space space": "editor::SelectAll",
      "space f": "vim::ToggleVisualLine",
      "space c": "editor::ToggleComments",

      "space p": "file_finder::Toggle",
      "space g": "pane::DeploySearch",
      "space b": "tab_switcher::ToggleAll",
      "space /": "buffer_search::Deploy",
      "space n": "project_panel::ToggleFocus",
      "space l f": "editor::Format",
      "space l d": "diagnostics::Deploy",
      "space l x": "diagnostics::Deploy",
      "space l shift-x": "diagnostics::Deploy",
      "space l s": "outline::Toggle",
      "space r": "editor::Rename",
      "space c a": "editor::ToggleCodeActions",
      "space h": "editor::Hover",

      "; q": ["pane::CloseActiveItem", { "save_intent": "save_all" }],
      "; shift-q": ["pane::CloseActiveItem", { "save_intent": "skip" }],
      "; w": ["workspace::SendKeystrokes", "v i w"],
      "; shift-w": ["workspace::SendKeystrokes", "v i shift-w"],
      "; shift-a": "vim::StartOfLine",
      "; shift-s": "vim::ToggleVisualLine",
      "; i": ["workspace::SendKeystrokes", "v i"],
      "; e": ["workspace::SendKeystrokes", "v a b e"],
      "; a": "editor::SelectAll",
      "; space": "editor::SelectAll",
      "; f": "vim::ToggleVisualLine",
      "; c": "editor::ToggleComments",
      "; p": "file_finder::Toggle",
      "; g": "pane::DeploySearch",
      "; b": "tab_switcher::ToggleAll",
      "; n": "project_panel::ToggleFocus",
      "; ;": "diagnostics::Deploy",

      "g d": "editor::GoToDefinition",
      "g shift-d": "editor::GoToDeclaration",
      "g i": "editor::GoToImplementation",
      "g r": "editor::FindAllReferences",
      "g t": "editor::GoToTypeDefinition",
      "] d": "editor::GoToDiagnostic",
      "[ d": "editor::GoToPreviousDiagnostic"
    }
  },
  {
    "context": "vim_mode == visual && !menu",
    "bindings": {
      "space": null,

      "w": ["vim::Up", { "display_lines": true }],
      "s": ["vim::Down", { "display_lines": true }],
      "a": "vim::Left",
      "d": "vim::Right",
      "shift-w": [
        "action::Sequence",
        [
          ["vim::Up", { "display_lines": true }],
          ["vim::Up", { "display_lines": true }],
          ["vim::Up", { "display_lines": true }],
          ["vim::Up", { "display_lines": true }],
          ["vim::Up", { "display_lines": true }]
        ]
      ],
      "shift-s": [
        "action::Sequence",
        [
          ["vim::Down", { "display_lines": true }],
          ["vim::Down", { "display_lines": true }],
          ["vim::Down", { "display_lines": true }],
          ["vim::Down", { "display_lines": true }],
          ["vim::Down", { "display_lines": true }]
        ]
      ],
      "shift-a": "vim::PreviousWordStart",
      "shift-d": "vim::NextWordEnd",
      "g l": "vim::EndOfLine",
      "r": "vim::ToggleVisualLine",
      "f": "vim::HelixJumpToWord",

      "<": "vim::Outdent",
      ">": "vim::Indent",
      "x": "editor::Delete",
      "shift-x": "vim::VisualDelete",
      "e": "vim::HelixSubstituteNoYank",
      "c": "vim::VisualYank",
      "space c": "editor::ToggleComments",
      "; c": "editor::ToggleComments"
    }
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "q": "vim::NormalBefore",
      "cmd-;": "editor::MoveToEndOfLine",
      "cmd-shift-;": ["editor::MoveToBeginningOfLine", { "stop_at_soft_wraps": false, "stop_at_indent": false }],
      "alt-backspace": ["editor::DeleteToPreviousWordStart", { "ignore_newlines": false, "ignore_brackets": false }]
    }
  },
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      "b": "vim::MiniBrackets",
      "q": "vim::MiniQuotes"
    }
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "ctrl-w w": "workspace::ActivatePaneUp",
      "ctrl-w s": "workspace::ActivatePaneDown",
      "ctrl-w a": "workspace::ActivatePaneLeft",
      "ctrl-w d": "workspace::ActivatePaneRight"
