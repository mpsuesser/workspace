{
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    "use_regex_search": true,
  },
  "outline_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "icon_theme": "Symbols Icon Theme",
  "tab_bar": {
    "show_nav_history_buttons": true,
    "show_tab_bar_buttons": true,
    "show": true,
  },
  "title_bar": {
    "show_branch_name": false,
  },
  "terminal": {
    "working_directory": {
      "always": {
        "directory": "/Users/m/_",
      },
    },
    "dock": "right",
    "default_height": 249.0,
    "shell": {
      "program": "zsh",
    },
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "cursor_blink": false,
  "close_on_file_delete": true,
  "centered_layout": {
    "left_padding": 0.25,
    "right_padding": 0.25,
  },
  "hover_popover_delay": 100,
  "minimap": {
    "show": "never",
  },
  "languages": {
    "TypeScript": {
      "soft_wrap": "prefer_line",
    },
  },
  "project_panel": {
    "indent_size": 20.0,
    "hide_root": true,
    "hide_gitignore": true,
    "default_width": 320.0,
    "hide_hidden": false,
    "bold_folder_labels": true,
    "dock": "right",
    "sort_mode": "directories_first",
    "indent_guides": {
      "show": "never",
    },
    "auto_fold_dirs": false,
    "folder_icons": false,
    "file_icons": true,
    "entry_spacing": "comfortable",
  },
  "edit_predictions": {
    "provider": "ollama",
    "ollama": {
      "model": "gemma4:26b"
    },
    "mode": "eager",
  },
  "buffer_font_family": ".ZedMono",
  "context_servers": {},
  "agent": {
    "button": true,
    "dock": "right",
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "profiles": {
      "TODO": {
        "name": "TODO",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "default_model": {
      "provider": "openai",
      "model": "gpt-5.5",
    },
    "model_parameters": [],
  },
  "ui_font_size": 14.0,
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Modern Vesper",
  },
}
